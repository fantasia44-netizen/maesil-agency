# ================================================================
# maesil-agency — 부트스트랩 시크릿만 .env에 둡니다.
# 다른 모든 키(Render API, 다른 Supabase, Anthropic 등)는
# 웹 /settings 페이지에서 입력 → autotool.agent_work.secrets 에 저장됩니다.
# ================================================================

# autotool Supabase (에이전트 작업 허브 / agent_work 스키마 호스트)
AUTOTOOL_SUPABASE_URL=https://pbocckpuiyzijspqpvqz.supabase.co
AUTOTOOL_SERVICE_ROLE_KEY=                 # Supabase Settings → API → service_role

# API Bearer 토큰 (프론트에서 /settings 에 입력하는 그 값과 동일해야 함)
API_BEARER_TOKEN=change-me

# CORS (프론트 로컬 개발)
CORS_ORIGINS=http://localhost:3000
